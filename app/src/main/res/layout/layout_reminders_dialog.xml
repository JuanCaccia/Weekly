<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minWidth="320dp"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_rounded_dialog">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recordatorios"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:textColor="?android:attr/textColorPrimary"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupReminders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">
        <!-- Reminders will be added here -->
    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:id="@+id/textRelativeHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Añadir aviso relativo"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:textColor="?android:attr/textColorPrimary"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupAddOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAdd5m"
            style="@style/Widget.MaterialComponents.Chip.Action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 min antes" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAdd15m"
            style="@style/Widget.MaterialComponents.Chip.Action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15 min antes" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAdd1h"
            style="@style/Widget.MaterialComponents.Chip.Action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 hora antes" />
    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:id="@+id/textSpecificHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Añadir momento específico"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:textColor="?android:attr/textColorPrimary"/>

    <com.google.android.material.chip.ChipGroup
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAddSpecific"
            style="@style/Widget.MaterialComponents.Chip.Action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Elegir hora y día..."
            app:chipIcon="@android:drawable/ic_menu_today"/>
    </com.google.android.material.chip.ChipGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDoneReminders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LISTO"
        app:cornerRadius="8dp" />

</LinearLayout>
