<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardDay"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:id="@+id/dayHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:paddingHorizontal="20dp"
            android:paddingVertical="18dp">

            <TextView
                android:id="@+id/textDayName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lunes"
                android:textColor="?attr/colorOnSurface"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textDayDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_toEndOf="@id/textDayName"
                android:layout_alignBaseline="@id/textDayName"
                android:text="24/5"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp" />

            <!-- Contenedor para Indicadores de Eventos Importantes -->
            <LinearLayout
                android:id="@+id/importantIndicatorsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_toEndOf="@id/textDayDate"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical" />

            <ImageView
                android:id="@+id/imageChevron"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_chevron_down"
                app:tint="?attr/colorPrimary" />
        </RelativeLayout>

        <!-- Expandable Content -->
        <LinearLayout
            android:id="@+id/expandableLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingBottom="16dp">

            <!-- All Day Tasks -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupAllDayTasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingBottom="12dp"
                app:chipSpacingVertical="4dp"
                app:chipSpacingHorizontal="8dp" />

            <!-- Mensaje de Día Vacío -->
            <TextView
                android:id="@+id/textNoActivities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="32dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Timeline View -->
            <FrameLayout
                android:id="@+id/layoutTimeline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorSurfaceVariant">

                <FrameLayout
                    android:id="@+id/timelineWrapper"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.example.weekly.ui.views.TimelineBackgroundView
                        android:id="@+id/timelineBackground"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/timelineContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="60dp" />
                </FrameLayout>

            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
