<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardTask"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgDragHandle"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_layers"
                app:tint="?attr/colorOnSurfaceVariant"
                android:padding="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <!-- Priority Indicator (Left strip) -->
            <View
                android:id="@+id/priorityIndicator"
                android:layout_width="4dp"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                android:background="#FF0000" />

            <CheckBox
                android:id="@+id/checkCompleted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:buttonTint="?attr/colorPrimary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/textTaskTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Título de la tarea"
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/textPriorityLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:text="ALTA"
                        android:textSize="10sp"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/imgCollisionAlert"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="4dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        app:tint="#F44336"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/imgBookmark"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_layers"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- Info Container (Time + Day + Overdue) -->
                <LinearLayout
                    android:id="@+id/timeContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:id="@+id/textTaskTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="09:00 - 10:00"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <!-- Day of week Text -->
                    <TextView
                        android:id="@+id/textDayOfWeek"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Lunes"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone" />

                    <!-- Overdue Text -->
                    <TextView
                        android:id="@+id/textOverdue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="hace 2 días"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textStyle="italic"
                        android:visibility="gone" />

                </LinearLayout>
            </LinearLayout>

            <View
                android:id="@+id/rescheduleBadge"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="?attr/colorPrimary"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/btnEditTask"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_edit"
                app:tint="?attr/colorPrimary"
                android:padding="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
