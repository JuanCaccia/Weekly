<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp"
    android:minHeight="64dp">

    <FrameLayout
        android:id="@+id/dayNumberContainer"
        android:layout_width="28dp"
        android:layout_height="28dp">

        <com.example.weekly.ui.views.MultiColorCircleView
            android:id="@+id/importantHighlight"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textDayNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="1"
            android:textSize="14sp"
            android:textColor="@color/text_primary_light" />
    </FrameLayout>

    <GridLayout
        android:id="@+id/containerDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:layout_marginTop="2dp"
        android:alignmentMode="alignBounds"
        android:useDefaultMargins="false">
        <!-- Dots will be added programmatically -->
    </GridLayout>

</LinearLayout>
